@startuml
title Administrative enheter kommuner - Objekttyper

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Objekttyper" {

  class Kommune <<featureType>> {
    + datafangstdato [0..1] : Date
    + datauttaksdato [0..1] : Date
    + opphav [0..1] : CharacterString
    + identifikasjon [1] : Identifikasjon
    + oppdateringsdato [1] : Date
    + gyldigFra [0..1] : Date
    + gyldigTil [0..1] : Date
    + område [1] : GM_MultiSurface
    + administrativEnhetNavn [1..*] : AdministrativEnhetNavn
    + kommunenummer [1] : Kommunenummer
    + kommunenavn [1] : CharacterString
    + samiskForvaltningsområde [0..1] : Boolean
  }

  abstract class SOSI_Objekt_flate <<featureType>> {
    ' Ingen attributter
  }

  class Grense <<featureType>> {
    + datafangstdato [0..1] : Date
    + kvalitet [0..1] : Posisjonskvalitet
    + datauttaksdato [0..1] : Date
    + opphav [0..1] : CharacterString
    + identifikasjon [1] : Identifikasjon
    + oppdateringsdato [1] : Date
    + gyldigFra [0..1] : Date
    + gyldigTil [0..1] : Date
    + grense [1] : GM_Curve
    + avgrensningstype [1] : TypeAvgrensning
  }

  abstract class SOSI_Fellesegenskaper <<featureType>> {
    ' Ingen attributter
  }

  abstract class SOSI_Objekt_grense <<featureType>> {
    ' Ingen attributter
  }

  class Fylke <<featureType>> {
    + datafangstdato [0..1] : Date
    + datauttaksdato [0..1] : Date
    + opphav [0..1] : CharacterString
    + identifikasjon [1] : Identifikasjon
    + oppdateringsdato [1] : Date
    + gyldigFra [0..1] : Date
    + gyldigTil [0..1] : Date
    + område [1] : GM_MultiSurface
    + administrativEnhetNavn [1..*] : AdministrativEnhetNavn
    + fylkesnummer [1] : Fylkesnummer
    + fylkesnavn [1] : CharacterString
    + samiskForvaltningsområde [0..1] : Boolean
  }

  class AdministrativEnhetNavn {
    + navn [1] : CharacterString
    + språk [1] : Språkkode
    + rekkefølge [0..1] : Integer
  }

  class Identifikasjon {
    + lokalId [1] : CharacterString
    + navnerom [1] : CharacterString
    + versjonId [0..1] : CharacterString
  }

  class Posisjonskvalitet {
    + målemetode [1] : Målemetode
    + nøyaktighet [0..1] : Integer
  }
}

  SOSI_Objekt_flate <|-- Kommune
  Kommune --> Grense : avgrensesAvGrense [0..*]
  SOSI_Fellesegenskaper <|-- SOSI_Objekt_flate
  SOSI_Objekt_grense <|-- Grense
  SOSI_Fellesegenskaper <|-- SOSI_Objekt_grense
  SOSI_Objekt_flate <|-- Fylke
  Fylke --> Grense : avgrensesAvGrense [0..*]

@enduml
